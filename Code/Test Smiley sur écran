void afficherHumeur(const unsigned char* bitmap, String message) {
  display.clearDisplay();
 
  // Dessiner le smiley centré
  display.drawBitmap((LARGEUR_ECRAN - 24) / 2, 10, bitmap, 24, 24, SSD1306_WHITE);
 
  // Paramètres du texte
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
 
  // Calculer la position X pour centrer le texte
  int16_t x1, y1;
  uint16_t w, h;
  display.getTextBounds(message, 0, 0, &x1, &y1, &w, &h);
  display.setCursor((LARGEUR_ECRAN - w) / 2, 45);
 
  display.println(message);
  display.display();
}


void setup() {
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    for(;;);
  }
}


void loop() {
  // 1. Tout va bien
  afficherHumeur(img_sourire, "Tout va bien !");
  delay(5000);


  // 2. Un peu sec
  afficherHumeur(img_neutre, "Un peu sec");
  delay(5000);


  // 3. Triste / Arroser
  afficherHumeur(img_triste, "Il faut arroser");
  delay(5000);
}
