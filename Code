#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <SHTSensor.h>
#include <LTR303.h>

// --- Configuration Écran OLED ---
#define LARGEUR_ECRAN 128
#define HAUTEUR_ECRAN 64
Adafruit_SSD1306 display(LARGEUR_ECRAN, HAUTEUR_ECRAN, &Wire, -1);

// --- Objets Capteurs ---
SHTSensor sht;
LTR303 light;
const int soilPin = A0; 

// --- Variables LTR303 ---
unsigned char gain = 0; 
unsigned char integrationTime = 0; 
unsigned char measurementRate = 3; 

// --- Variables de gestion du temps ---
unsigned long previousMillis = 0;
const long interval = 5000; // 5 secondes
bool montrerSmiley = true;

// --- Bitmaps (24x24 pixels) ---
